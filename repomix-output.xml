                    >
                      {getWishlistCount()}
                    </motion.span>
                  )}
                </Button>
              </Link>
              
              <Button
                variant="ghost"
                size="icon"
                onClick={handleAccountClick}
                className="sm:flex"
              >
                <User className="h-5 w-5" />
              </Button>

              <Link to="/cart" className="relative">
                <Button variant="ghost" size="icon">
                  <ShoppingBag className="h-5 w-5" />
